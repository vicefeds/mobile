-- AutoPlay Mobile | Extraído de Vyse Slotted v2.1
-- Al ejecutar, inicia el AutoPlay automáticamente

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LP = Players.LocalPlayer

-- ══ Configuración ══
local normalSpeed = 60
local carrySpeed  = 30
local AUTO_START_DELAY = 1

-- ══ Waypoints ══
local AP_RIGHT_WP = {
	Vector3.new(-473.04,-6.99,29.71),
	Vector3.new(-481.89,-5.20,26.20),
	Vector3.new(-475.00,-6.99,26.43),
	Vector3.new(-474.67,-6.94,105.48),
}
local AP_LEFT_WP = {
	Vector3.new(-472.49,-7.00,90.62),
	Vector3.new(-482.03,-5.13,94.63),
	Vector3.new(-475.08,-7.00,93.29),
	Vector3.new(-474.22,-6.96,16.18),
}

local POS = {
	RETURN_L = Vector3.new(-475.27,-6.99,94.54),
	RETURN_R = Vector3.new(-475.22,-6.99,23.63),
}

-- ══ Estado ══
local State = {
	enabled   = false,
	waypoint  = 1,
	waiting   = false,
	side      = nil,
}

local autoPlayConn = nil

-- ══ Detección de lado (base) ══
local function findMyPlot()
	local plots = workspace:FindFirstChild("Plots")
	if not plots then return nil end
	local name = LP.DisplayName or LP.Name
	local nameLower = name:lower()
	for _, plot in plots:GetChildren() do
		local sign = plot:FindFirstChild("PlotSign")
		if not sign then continue end
		local yb = sign:FindFirstChild("YourBase")
		if yb and yb:IsA("BillboardGui") and yb.Enabled then return plot end
		local sg = sign:FindFirstChild("SurfaceGui")
		if not sg then continue end
		local fr = sg:FindFirstChild("Frame")
		if not fr then continue end
		local lbl = fr:FindFirstChild("TextLabel")
		if lbl and typeof(lbl.Text) == "string" and lbl.Text ~= "" then
			local t = lbl.Text:lower()
			if t:find(nameLower, 1, true) and t:find("'s base", 1, true) then return plot end
		end
	end
	return nil
end

local function getPlotPosition(plot)
	if not plot then return nil end
	if plot.PrimaryPart then return plot.PrimaryPart.Position end
	local sign = plot:FindFirstChild("PlotSign")
	if sign then
		local p = sign:IsA("BasePart") and sign or sign:FindFirstChildWhichIsA("BasePart")
		if p then return p.Position end
	end
	local sum, count = Vector3.zero, 0
	for _, obj in plot:GetDescendants() do
		if obj:IsA("BasePart") then sum += obj.Position; count += 1 end
	end
	return count > 0 and (sum / count) or nil
end

local function getBaseSide()
	local myPlot
	for _ = 1, 15 do
		myPlot = findMyPlot()
		if myPlot then break end
		task.wait(1)
	end
	if myPlot then
		local bp = getPlotPosition(myPlot)
		if bp then
			return (bp - POS.RETURN_R).Magnitude < (bp - POS.RETURN_L).Magnitude and "right" or "left"
		end
	end
	-- fallback por posición del jugador
	local char = LP.Character
	if char then
		local root = char:FindFirstChild("HumanoidRootPart")
		if root then
			local dR = (root.Position - POS.RETURN_R).Magnitude
			local dL = (root.Position - POS.RETURN_L).Magnitude
			if math.abs(dR - dL) > 10 then
				return dR < dL and "right" or "left"
			end
		end
	end
	return "left"
end

-- ══ Countdown check ══
local function isCountdownNum(text)
	local n = tonumber(text)
	return n and n >= 1 and n <= 5
end
local function getTimerLabel()
	local ok, lbl = pcall(function()
		return LP.PlayerGui:FindFirstChild("DuelsMachineTopFrame")
			and LP.PlayerGui.DuelsMachineTopFrame:FindFirstChild("DuelsMachineTopFrame")
			and LP.PlayerGui.DuelsMachineTopFrame.DuelsMachineTopFrame:FindFirstChild("Timer")
			and LP.PlayerGui.DuelsMachineTopFrame.DuelsMachineTopFrame.Timer:FindFirstChild("Label")
	end)
	return ok and lbl or nil
end
local function isInCountdown()
	local lbl = getTimerLabel()
	return lbl and isCountdownNum(lbl.Text)
end

-- ══ Stop AutoPlay ══
local function stopAutoPlay()
	State.enabled  = false
	State.waypoint = 1
	State.waiting  = false
	if autoPlayConn then autoPlayConn:Disconnect(); autoPlayConn = nil end
	local char = LP.Character
	if char then
		local root = char:FindFirstChild("HumanoidRootPart")
		local hum  = char:FindFirstChildOfClass("Humanoid")
		if root then root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0) end
		if hum  then hum:Move(Vector3.zero, false) end
	end
	print("[AutoPlay] Terminado.")
end

-- ══ Movement loop ══
local function startMovement()
	if autoPlayConn then autoPlayConn:Disconnect() end
	State.waypoint = 1
	State.waiting  = false

	autoPlayConn = RunService.Heartbeat:Connect(function()
		if not State.enabled then return end
		local char = LP.Character
		if not char then return end
		local root = char:FindFirstChild("HumanoidRootPart")
		local hum  = char:FindFirstChildOfClass("Humanoid")
		if not root or not hum then return end

		local wps = State.side == "right" and AP_RIGHT_WP or AP_LEFT_WP

		if State.waypoint > #wps then
			stopAutoPlay()
			return
		end

		if State.waiting then
			root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
			return
		end

		local tp  = wps[State.waypoint]
		local txz = Vector3.new(tp.X, 0, tp.Z)
		local cxz = Vector3.new(root.Position.X, 0, root.Position.Z)
		local distXZ = (txz - cxz).Magnitude
		local dist3D = (tp - root.Position).Magnitude

		local arrivalDist = (State.waypoint == 2) and 0.1 or 3
		local arrived = (State.waypoint == 2) and (dist3D <= arrivalDist) or (distXZ <= arrivalDist)
		local spd = State.waypoint > 2 and carrySpeed or normalSpeed

		if not arrived then
			local md = (txz - cxz).Unit
			root.AssemblyLinearVelocity = Vector3.new(md.X * spd, root.AssemblyLinearVelocity.Y, md.Z * spd)
		else
			if State.waypoint == 2 then
				root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
				State.waiting = true
				task.spawn(function()
					task.wait(0.12)
					if State.enabled then
						State.waiting  = false
						State.waypoint = 3
					end
				end)
			elseif State.waypoint == #wps then
				root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
				stopAutoPlay()
			else
				State.waypoint += 1
			end
		end
	end)
end

-- ══ Iniciar AutoPlay ══
local function startAutoPlay()
	State.enabled = true
	print("[AutoPlay] Detectando lado...")

	task.spawn(function()
		local side = getBaseSide()
		State.side = (side == "right") and "left" or "right"
		print("[AutoPlay] Lado detectado: " .. State.side)

		if not State.enabled then return end

		if isInCountdown() then
			print("[AutoPlay] Countdown detectado, esperando '1'...")
			local lbl = getTimerLabel()
			if lbl then
				local conn
				conn = lbl:GetPropertyChangedSignal("Text"):Connect(function()
					if isCountdownNum(lbl.Text) and tonumber(lbl.Text) == 1 then
						conn:Disconnect()
						task.wait(AUTO_START_DELAY)
						if State.enabled then
							print("[AutoPlay] Iniciando movimiento!")
							startMovement()
						end
					end
				end)
			else
				startMovement()
			end
		else
			print("[AutoPlay] Sin countdown, iniciando de inmediato.")
			startMovement()
		end
	end)
end

-- ══ EJECUTAR ══
startAutoPlay()
